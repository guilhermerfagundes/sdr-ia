# ============================================================
#  EXEMPLO de secrets para o Streamlit Cloud.
#  NÃO coloque segredos reais aqui (este arquivo vai pro GitHub).
#  No Streamlit Cloud: app → Settings → Secrets → cole o conteúdo
#  REAL (sem o ".example" no nome).
#  Localmente, você normalmente NÃO precisa deste arquivo —
#  use o .env e o auth_config.yaml.
# ============================================================

# Banco de dados Postgres (Supabase/Neon). Exige SSL.
DATABASE_URL = "postgresql://usuario:senha@host:5432/postgres?sslmode=require"

# Chave da Google Places API (opcional)
GOOGLE_PLACES_API_KEY = "sua_chave_aqui"

# Login do painel — gere com:  python tools/set_password.py
[auth.credentials.usernames.admin]
name = "Administrador"
password = "$2b$12$COLOQUE_O_HASH_GERADO_AQUI"
email = ""

[auth.cookie]
name = "sdr_ia_auth"
key = "troque_por_uma_chave_aleatoria_longa"
expiry_days = 30
